<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="@color/card_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">


            <!-- Hero image -->
            <ImageView
                android:id="@+id/iv_ideal_hero"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:scaleType="centerCrop"
                android:src="@drawable/alex_der_cutie"
                app:cardCornerRadius="60dp"/>

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textSize="32sp"
                android:layout_gravity="center_horizontal"
                android:textColor="@color/accent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Your Ideal Match"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_gravity="center_horizontal"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Based on your 50 swipes, this is what your heart wants"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_gravity="center_horizontal"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="@color/divider"/>

            <!-- Traits grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🐾  Species" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_ideal_species" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚧  Gender" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_ideal_gender" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎂  Age" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_ideal_age" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📍  Location" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_ideal_location" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎨  Fur Color" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_ideal_fur" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌀  Tail Type" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_ideal_tail" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡  Top Activity" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_ideal_activity" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✨  Top Trait" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_ideal_trait" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="@color/divider"/>

            <!-- Continue button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_continue"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/accent">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Keep Swiping ✦"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>