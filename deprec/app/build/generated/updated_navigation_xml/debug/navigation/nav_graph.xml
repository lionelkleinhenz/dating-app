<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/nav_graph"
app:startDestination="@id/FirstFragment" >
<fragment
    android:id="@+id/FirstFragment"
    android:name="com.example.datingapp.FirstFragment"
    android:label="@string/first_fragment_label"
    tools:layout="@layout/fragment_first" >

    <action
        android:id="@+id/action_FirstFragment_to_SecondFragment"
        app:destination="@id/SecondFragment" />
    <action
        android:id="@+id/action_FirstFragment_self"
        app:destination="@id/FirstFragment" />
    <action
        android:id="@+id/action_FirstFragment_to_SecondSecondFragment"
        app:destination="@id/SecondSecondFragment" />

</fragment>
<fragment
    android:id="@+id/SecondFragment"
    android:name="com.example.datingapp.SecondFragment"
    android:label="@string/second_fragment_label"
    tools:layout="@layout/fragment_second" >

    <action
        android:id="@+id/action_SecondFragment_to_FirstFragment"
        app:destination="@id/FirstFragment" />

</fragment>
<fragment
    android:id="@+id/SecondSecondFragment"
    android:name="com.example.datingapp.SecondSecondFragment"
    android:label="@string/second_second_fragment_label"
    tools:layout="@layout/fragment_second_second" >

    <action
        android:id="@+id/action_SecondSecondFragment_to_FirstFragment"
        app:destination="@id/FirstFragment" />

</fragment>
</navigation>